---
interface Props {
	npmPackage?: string;
	githubRepo?: string;
}

const { npmPackage = "draht-claude", githubRepo = "draht-dev/draht" } = Astro.props;

const packages: { name: string; tagline: string }[] = [
	{ name: "@draht/router", tagline: "the dispatcher" },
	{ name: "@draht/orchestrator", tagline: "the conductor" },
	{ name: "@draht/knowledge", tagline: "the domain" },
	{ name: "@draht/tdd", tagline: "the red bar" },
	{ name: "@draht/ci", tagline: "the gate" },
	{ name: "@draht/deploy-guardian", tagline: "the sentinel" },
	{ name: "@draht/invoice", tagline: "the ledger" },
	{ name: "@draht/compliance", tagline: "the notary" },
	{ name: "@draht/templates", tagline: "the patterns" },
	{ name: "draht-claude", tagline: "the bridge" },
	{ name: "@draht/cli", tagline: "the standalone" },
	{ name: "@draht/ai", tagline: "the primitives" },
	{ name: "@draht/extensions", tagline: "the slots" },
	{ name: "@draht/tui", tagline: "the loom" },
	{ name: "@draht/pods", tagline: "the foundry" },
];

let initialVersion = "—";
let initialStars: number | null = null;

try {
	const res = await fetch(`https://registry.npmjs.org/${npmPackage}/latest`, {
		headers: { Accept: "application/json" },
	});
	if (res.ok) {
		const data = (await res.json()) as { version?: string };
		if (data.version) initialVersion = data.version;
	}
} catch {
	/* keep fallback */
}

try {
	const res = await fetch(`https://api.github.com/repos/${githubRepo}`, {
		headers: {
			Accept: "application/vnd.github.v3+json",
			"User-Agent": "draht-landing",
			...(import.meta.env.GITHUB_TOKEN ? { Authorization: `Bearer ${import.meta.env.GITHUB_TOKEN}` } : {}),
		},
	});
	if (res.ok) {
		const data = (await res.json()) as { stargazers_count?: number };
		if (typeof data.stargazers_count === "number") initialStars = data.stargazers_count;
	}
} catch {
	/* keep fallback */
}

const starsLabel = initialStars === null ? "—" : initialStars.toLocaleString("en-US");
---

<header
	class="topbar"
	data-npm-package={npmPackage}
	data-github-repo={githubRepo}
>
	<a class="brand" href="/">
		<span class="mark"><img src="/draht-logo.webp" alt="draht logo" width="34" height="34" /></span>
		<span class="wordmark">draht &nbsp; <em>/dʁaːt/</em></span>
	</a>

	<svg class="navwire" id="navwire" aria-hidden="true" preserveAspectRatio="none"></svg>

	<nav class="topnav" id="topnav">
		<a href="/#werkstatt" data-nav-link>Workflow</a>
		<a href="/#packages" data-nav-link>Packages</a>
		<a href="/#philosophie" data-nav-link>Prinzipien</a>
		<a href="/#pricing" data-nav-link>Pricing</a>
		<a href="/docs" data-nav-link>Docs</a>
		<a href="/blog" data-nav-link>Blog</a>
		<a href={`https://github.com/${githubRepo}`} class="gh-link" data-nav-link>
			<svg
				class="gh-star"
				viewBox="0 0 24 24"
				width="13"
				height="13"
				aria-hidden="true"
				fill="currentColor"
			>
				<path d="M12 2.5l2.95 5.98 6.6.96-4.78 4.66 1.13 6.58L12 17.6l-5.9 3.1 1.13-6.58L2.45 9.44l6.6-.96L12 2.5z" />
			</svg>
			<span class="gh-stars" data-gh-stars>{starsLabel}</span>
			<span class="gh-text">GitHub ↗</span>
		</a>
	</nav>

	<button class="burger" id="burger" aria-label="Toggle menu" aria-expanded="false">
		<span class="burger-line"></span>
		<span class="burger-line"></span>
		<span class="burger-line"></span>
	</button>
</header>

<div class="meta-strip">
	<span>
		<span class="dot"></span>
		<span class="pkg-menu" id="pkg-menu">
			<button
				type="button"
				class="version-link"
				id="pkg-menu-toggle"
				aria-haspopup="menu"
				aria-expanded="false"
				aria-controls="pkg-menu-list"
			>v<span data-version>{initialVersion}</span></button>
			<div class="pkg-menu-pop" id="pkg-menu-list" role="menu" aria-label="Packages">
				<div class="pkg-menu-head">
					<span>15 packages</span>
					<a
						class="pkg-menu-current"
						href={`https://www.npmjs.com/package/${npmPackage}`}
						target="_blank"
						rel="noopener"
						role="menuitem"
					>{npmPackage} ↗</a>
				</div>
				<ul class="pkg-menu-items">
					{packages.map((p) => (
						<li>
							<a
								href={`https://www.npmjs.com/package/${p.name}`}
								target="_blank"
								rel="noopener"
								role="menuitem"
							>
								<span class="pkg-menu-name">{p.name}</span>
								<em class="pkg-menu-tag">{p.tagline}</em>
								<span class="pkg-menu-arrow" aria-hidden="true">↗</span>
							</a>
						</li>
					))}
				</ul>
			</div>
		</span>
		· built in Dortmund · MIT
	</span>
	<span>N° 001 / MONOREPO · 15 PACKAGES</span>
	<span>HANDGEFERTIGT — OSKAR FREYE, MMXXVI</span>
</div>

<style>
	.topbar {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding-top: 28px;
		padding-bottom: 14px;
		border-bottom: 1px solid var(--rule);
		gap: 16px;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 14px;
		font-family: var(--f-ui);
		letter-spacing: 0.02em;
		position: relative;
		z-index: 1;
	}
	.brand .mark {
		width: 34px;
		height: 34px;
		display: grid;
		place-items: center;
		position: relative;
	}
	.brand .mark img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		filter: drop-shadow(0 0 6px rgba(217, 140, 70, 0.18));
	}
	.brand .wordmark {
		font-size: 15px;
		letter-spacing: 0.06em;
		text-transform: lowercase;
	}
	.brand .wordmark em {
		font-style: normal;
		color: var(--paper-soft);
	}

	.topnav {
		display: flex;
		gap: 28px;
		font-size: 13px;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--paper-soft);
		position: relative;
		z-index: 1;
	}
	.topnav a {
		position: relative;
		padding: 4px 0;
	}
	.topnav a:hover { color: var(--paper); }
	.topnav a::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		bottom: -2px;
		height: 1px;
		background: var(--copper);
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 0.3s ease;
	}
	.topnav a:hover::after { transform: scaleX(1); }
	.topnav a.active { color: var(--paper); }
	.topnav a.active::after { transform: scaleX(1); }

	.burger {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 4px;
		width: 32px;
		height: 32px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 4px;
		z-index: 1;
	}
	.burger-line {
		display: block;
		width: 100%;
		height: 2px;
		background: var(--paper);
		border-radius: 1px;
		transition: transform 0.3s, opacity 0.3s;
	}
	.burger[aria-expanded="true"] .burger-line:nth-child(1) { transform: translateY(6px) rotate(45deg); }
	.burger[aria-expanded="true"] .burger-line:nth-child(2) { opacity: 0; }
	.burger[aria-expanded="true"] .burger-line:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

	.meta-strip {
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-family: var(--f-mono);
		font-size: 11px;
		color: var(--paper-soft);
		letter-spacing: 0.04em;
		padding: 10px 0;
		border-bottom: 1px solid var(--rule);
	}
	.meta-strip .dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--patina);
		display: inline-block;
		margin-right: 8px;
		vertical-align: middle;
		animation: nav-blink 2.4s infinite;
	}
	@keyframes nav-blink {
		0%, 100% { opacity: 1; }
		50%      { opacity: 0.25; }
	}
	.meta-strip .pkg-menu {
		position: relative;
		display: inline-block;
	}
	.meta-strip .version-link {
		color: inherit;
		font: inherit;
		letter-spacing: inherit;
		background: none;
		border: none;
		border-bottom: 1px dotted color-mix(in oklab, var(--copper-dim), transparent 50%);
		padding: 0;
		cursor: pointer;
		transition: color 0.2s ease, border-color 0.2s ease;
	}
	.meta-strip .version-link:hover,
	.meta-strip .pkg-menu.open .version-link {
		color: var(--copper);
		border-bottom-color: var(--copper);
	}

	.meta-strip .pkg-menu-pop {
		position: absolute;
		top: calc(100% + 8px);
		left: -8px;
		z-index: 50;
		min-width: 280px;
		max-width: 360px;
		background: var(--ink);
		border: 1px solid var(--rule-strong);
		box-shadow: 0 12px 40px rgba(0, 0, 0, 0.55), 0 0 0 1px var(--rule);
		padding: 10px 0 6px;
		opacity: 0;
		transform: translateY(-4px);
		pointer-events: none;
		transition: opacity 0.15s ease, transform 0.15s ease;
	}
	.meta-strip .pkg-menu:hover .pkg-menu-pop,
	.meta-strip .pkg-menu:focus-within .pkg-menu-pop,
	.meta-strip .pkg-menu.open .pkg-menu-pop {
		opacity: 1;
		transform: translateY(0);
		pointer-events: auto;
	}
	.meta-strip .pkg-menu-head {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 12px;
		padding: 0 14px 8px;
		margin-bottom: 4px;
		border-bottom: 1px solid var(--rule);
		font-size: 10px;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--paper-soft);
	}
	.meta-strip .pkg-menu-current {
		color: var(--copper);
		text-decoration: none;
	}
	.meta-strip .pkg-menu-current:hover { color: var(--paper); }
	.meta-strip .pkg-menu-items {
		list-style: none;
		margin: 0;
		padding: 0;
		max-height: 60vh;
		overflow-y: auto;
	}
	.meta-strip .pkg-menu-items li { margin: 0; }
	.meta-strip .pkg-menu-items a {
		display: grid;
		grid-template-columns: 1fr auto auto;
		align-items: baseline;
		gap: 10px;
		padding: 7px 14px;
		text-decoration: none;
		color: var(--paper-dim);
		transition: background 0.15s ease, color 0.15s ease;
	}
	.meta-strip .pkg-menu-items a:hover {
		background: color-mix(in oklab, var(--copper), transparent 92%);
		color: var(--paper);
	}
	.meta-strip .pkg-menu-name {
		font-family: var(--f-mono);
		font-size: 12px;
		letter-spacing: 0.02em;
		text-transform: none;
	}
	.meta-strip .pkg-menu-tag {
		font-style: italic;
		font-size: 11px;
		color: var(--paper-soft);
		text-transform: lowercase;
		letter-spacing: 0;
	}
	.meta-strip .pkg-menu-items a:hover .pkg-menu-tag { color: var(--copper); }
	.meta-strip .pkg-menu-arrow {
		font-size: 11px;
		color: var(--paper-soft);
		opacity: 0.5;
	}
	.meta-strip .pkg-menu-items a:hover .pkg-menu-arrow {
		color: var(--copper);
		opacity: 1;
	}

	@media (max-width: 600px) {
		.meta-strip .pkg-menu-pop {
			left: 0;
			right: auto;
			min-width: min(320px, calc(100vw - 32px));
		}
	}

	.navwire {
		position: absolute;
		left: 0;
		right: 0;
		top: 0;
		bottom: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		overflow: visible;
		z-index: 0;
	}

	.gh-link {
		display: inline-flex;
		align-items: center;
		gap: 6px;
	}
	.gh-link .gh-star {
		color: var(--copper);
		filter: drop-shadow(0 0 4px color-mix(in oklab, var(--copper), transparent 60%));
	}
	.gh-link .gh-stars {
		font-family: var(--f-mono);
		font-size: 11px;
		color: var(--paper-soft);
		letter-spacing: 0.04em;
	}
	.gh-link:hover .gh-stars { color: var(--paper); }

	.nav-bus {
		fill: none;
		stroke: var(--copper-dim);
		stroke-width: 1;
		opacity: 0.45;
	}
	.nav-bus-pulse {
		fill: none;
		stroke: var(--copper);
		stroke-width: 1.6;
		stroke-linecap: round;
		filter: drop-shadow(0 0 4px var(--copper)) drop-shadow(0 0 10px var(--copper-dim));
	}
	.nav-branch {
		fill: none;
		stroke: var(--copper-dim);
		stroke-width: 1;
		opacity: 0.4;
	}
	.nav-branch-pulse {
		fill: none;
		stroke: var(--copper);
		stroke-width: 1.4;
		stroke-linecap: round;
		filter: drop-shadow(0 0 3px var(--copper));
	}
	.nav-node {
		fill: var(--ink);
		stroke: var(--copper);
		stroke-width: 1;
	}

	@media (max-width: 820px) {
		.navwire { display: none; }
		.gh-link .gh-text { display: none; }
		.burger { display: flex; }
		.topnav {
			display: none;
			position: absolute;
			top: calc(100% + 8px);
			right: 0;
			left: 0;
			flex-direction: column;
			gap: 0;
			background: var(--ink);
			border: 1px solid var(--rule);
			padding: 8px 0;
			z-index: 10;
		}
		.topnav.open { display: flex; }
		.topnav a { padding: 10px 20px; }
		.topnav a::after { display: none; }
	}
	@media (max-width: 900px) {
		.meta-strip { flex-direction: column; align-items: flex-start; gap: 4px; }
	}
</style>

<script>
	type StarsResponse = { stargazers_count?: number };
	type NpmResponse = { version?: string };

	function refreshStars(repo: string) {
		fetch(`https://api.github.com/repos/${repo}`, {
			headers: { Accept: "application/vnd.github.v3+json" },
		})
			.then((r) => (r.ok ? (r.json() as Promise<StarsResponse>) : null))
			.then((data) => {
				if (!data || typeof data.stargazers_count !== "number") return;
				const el = document.querySelector<HTMLElement>("[data-gh-stars]");
				if (el) el.textContent = data.stargazers_count.toLocaleString("en-US");
			})
			.catch(() => {});
	}

	function refreshVersion(pkg: string) {
		fetch(`https://registry.npmjs.org/${pkg}/latest`, { headers: { Accept: "application/json" } })
			.then((r) => (r.ok ? (r.json() as Promise<NpmResponse>) : null))
			.then((data) => {
				if (!data || !data.version) return;
				document.querySelectorAll<HTMLElement>("[data-version]").forEach((el) => {
					el.textContent = data.version!;
				});
			})
			.catch(() => {});
	}

	function buildNavWire() {
		const topbar = document.querySelector<HTMLElement>(".topbar");
		const svg = document.getElementById("navwire") as SVGSVGElement | null;
		const navAnchors = Array.from(document.querySelectorAll<HTMLAnchorElement>(".topnav [data-nav-link]"));
		if (!topbar || !svg || navAnchors.length === 0) return;

		const tbRect = topbar.getBoundingClientRect();
		if (tbRect.width === 0) return;

		const W = tbRect.width;
		const H = tbRect.height;
		svg.setAttribute("viewBox", `0 0 ${W} ${H}`);
		svg.setAttribute("width", String(W));
		svg.setAttribute("height", String(H));
		svg.innerHTML = "";

		const SVG_NS = "http://www.w3.org/2000/svg";
		const branches: { x: number; y: number }[] = [];

		for (const a of navAnchors) {
			const r = a.getBoundingClientRect();
			branches.push({
				x: r.left - tbRect.left + r.width / 2,
				y: r.top - tbRect.top + r.height,
			});
		}
		if (branches.length === 0) return;

		const busY = Math.min(...branches.map((b) => b.y)) + 6;
		const busStartX = Math.max(0, branches[0].x - 40);
		const busEndX = Math.min(W, branches[branches.length - 1].x + 40);

		const bus = document.createElementNS(SVG_NS, "path");
		const busD = `M ${busStartX} ${busY} L ${busEndX} ${busY}`;
		bus.setAttribute("d", busD);
		bus.setAttribute("class", "nav-bus");
		svg.appendChild(bus);

		const busLength = busEndX - busStartX;
		const busPulse = document.createElementNS(SVG_NS, "path");
		busPulse.setAttribute("d", busD);
		busPulse.setAttribute("class", "nav-bus-pulse");
		busPulse.setAttribute("stroke-dasharray", `14 ${busLength + 80}`);
		svg.appendChild(busPulse);

		const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
		const busDuration = 6000;
		if (!reduce) {
			busPulse.animate(
				[{ strokeDashoffset: 0 }, { strokeDashoffset: -(busLength + 94) }],
				{ duration: busDuration, iterations: Infinity, easing: "linear" },
			);
		}

		for (const b of branches) {
			const branchEndY = b.y - 4;
			const branchD = `M ${b.x} ${busY} L ${b.x} ${branchEndY}`;
			const branch = document.createElementNS(SVG_NS, "path");
			branch.setAttribute("d", branchD);
			branch.setAttribute("class", "nav-branch");
			svg.appendChild(branch);

			const branchLen = busY - branchEndY;
			if (branchLen > 0) {
				const branchPulse = document.createElementNS(SVG_NS, "path");
				branchPulse.setAttribute("d", branchD);
				branchPulse.setAttribute("class", "nav-branch-pulse");
				branchPulse.setAttribute("stroke-dasharray", `8 ${branchLen + 80}`);
				svg.appendChild(branchPulse);

				if (!reduce) {
					const tFire = ((b.x - busStartX) / busLength) * busDuration;
					const advance = ((busDuration - (tFire % busDuration)) % busDuration + busDuration) % busDuration;
					const branchAnim = branchPulse.animate(
						[{ strokeDashoffset: 0 }, { strokeDashoffset: -(branchLen + 88) }],
						{ duration: busDuration, iterations: Infinity, easing: "linear" },
					);
					branchAnim.currentTime = advance;
				}
			}

			const node = document.createElementNS(SVG_NS, "circle");
			node.setAttribute("cx", String(b.x));
			node.setAttribute("cy", String(busY));
			node.setAttribute("r", "2");
			node.setAttribute("class", "nav-node");
			svg.appendChild(node);
		}
	}

	function init() {
		const topbar = document.querySelector<HTMLElement>(".topbar");
		if (!topbar) return;

		const repo = topbar.dataset.githubRepo;
		const pkg = topbar.dataset.npmPackage;
		if (repo) refreshStars(repo);
		if (pkg) refreshVersion(pkg);

		const burger = document.getElementById("burger") as HTMLButtonElement | null;
		const topnav = document.getElementById("topnav") as HTMLElement | null;
		if (burger && topnav) {
			burger.addEventListener("click", () => {
				const open = topnav.classList.toggle("open");
				burger.setAttribute("aria-expanded", String(open));
			});
			topnav.querySelectorAll("a").forEach((a) => {
				a.addEventListener("click", () => {
					burger.setAttribute("aria-expanded", "false");
					topnav.classList.remove("open");
				});
			});
		}

		const path = window.location.pathname;
		document.querySelectorAll<HTMLAnchorElement>(".topnav a").forEach((a) => {
			const href = a.getAttribute("href") ?? "";
			if (href.startsWith("/") && !href.startsWith("/#") && href !== "/" && path.startsWith(href)) {
				a.classList.add("active");
			}
		});

		const pkgMenu = document.getElementById("pkg-menu");
		const pkgToggle = document.getElementById("pkg-menu-toggle");
		if (pkgMenu && pkgToggle) {
			pkgToggle.addEventListener("click", (e) => {
				e.stopPropagation();
				const open = pkgMenu.classList.toggle("open");
				pkgToggle.setAttribute("aria-expanded", String(open));
			});
			document.addEventListener("click", (e) => {
				if (!pkgMenu.contains(e.target as Node)) {
					pkgMenu.classList.remove("open");
					pkgToggle.setAttribute("aria-expanded", "false");
				}
			});
			document.addEventListener("keydown", (e) => {
				if (e.key === "Escape" && pkgMenu.classList.contains("open")) {
					pkgMenu.classList.remove("open");
					pkgToggle.setAttribute("aria-expanded", "false");
					pkgToggle.focus();
				}
			});
		}

		buildNavWire();

		let resizeRaf = 0;
		window.addEventListener("resize", () => {
			cancelAnimationFrame(resizeRaf);
			resizeRaf = requestAnimationFrame(buildNavWire);
		});

		const fonts = (document as Document & { fonts?: { ready?: Promise<unknown> } }).fonts;
		if (fonts && fonts.ready) {
			fonts.ready.then(buildNavWire).catch(() => {});
		}
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", init);
	} else {
		init();
	}
</script>
