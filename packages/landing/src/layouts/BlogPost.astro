---
import AtelierPage from "./AtelierPage.astro";

interface Props {
	title: string;
	description: string;
	date: string;
	author?: string;
	tags?: string[];
}

const { title, description, date, author, tags } = Astro.props;
const pageTitle = `${title} — Draht Blog`;
---

<AtelierPage title={pageTitle} description={description}>
	<article class="post">
		<header class="post-header">
			<a href="/blog" class="back-link">← Back to Journal</a>
			<div class="post-meta-row">
				<time class="post-date">{date}</time>
				{author && <span class="post-author">· {author}</span>}
			</div>
			<h1 class="post-title">{title}</h1>
			<p class="post-desc">{description}</p>
			{tags && tags.length > 0 && (
				<div class="post-tags">
					{tags.map((tag) => (
						<span class="tag">{tag}</span>
					))}
				</div>
			)}
		</header>

		<div class="post-content">
			<slot />
		</div>

		<footer class="post-footer">
			<a href="/blog" class="back-link">← Back to Journal</a>
		</footer>
	</article>
</AtelierPage>

<style>
	.post {
		max-width: 720px;
		margin: 0 auto;
	}

	.post-header {
		padding: clamp(40px, 7vw, 80px) 0 clamp(28px, 4vw, 48px);
		border-bottom: 1px solid var(--rule);
	}

	.back-link {
		display: inline-block;
		font-family: var(--f-mono);
		color: var(--paper-soft);
		font-size: 11px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		margin-bottom: 32px;
		transition: color 0.2s;
	}
	.back-link:hover {
		color: var(--copper);
	}

	.post-meta-row {
		display: flex;
		gap: 10px;
		align-items: center;
		margin-bottom: 20px;
		font-family: var(--f-mono);
		font-size: 11px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.post-date {
		color: var(--copper);
	}

	.post-author {
		color: var(--paper-soft);
	}

	.post-title {
		font-family: var(--f-display);
		font-style: italic;
		font-weight: 300;
		font-size: clamp(40px, 6vw, 68px);
		line-height: 1.02;
		letter-spacing: -0.025em;
		color: var(--paper);
		margin: 0 0 24px;
		text-wrap: balance;
	}

	.post-desc {
		font-family: var(--f-display);
		color: var(--paper-dim);
		font-size: clamp(18px, 2vw, 22px);
		line-height: 1.5;
		margin: 0 0 24px;
		max-width: 50ch;
		text-wrap: pretty;
	}

	.post-tags {
		display: flex;
		gap: 8px;
		flex-wrap: wrap;
		margin-top: 20px;
	}

	.tag {
		font-family: var(--f-mono);
		font-size: 10px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--copper-dim);
		padding: 4px 10px;
		border: 1px solid var(--rule-strong);
	}

	.post-content {
		padding: clamp(32px, 5vw, 64px) 0;
		font-family: var(--f-ui);
		font-size: 16px;
		line-height: 1.75;
		color: var(--paper);
	}

	.post-content :global(h2) {
		font-family: var(--f-display);
		font-style: italic;
		font-weight: 400;
		font-size: clamp(28px, 3.5vw, 36px);
		letter-spacing: -0.02em;
		line-height: 1.15;
		color: var(--paper);
		margin: 3rem 0 1rem;
		padding-top: 2rem;
		border-top: 1px solid var(--rule);
	}
	.post-content :global(h2:first-child) {
		border-top: none;
		padding-top: 0;
		margin-top: 0;
	}

	.post-content :global(h3) {
		font-family: var(--f-display);
		font-weight: 400;
		font-size: clamp(20px, 2.2vw, 24px);
		letter-spacing: -0.01em;
		color: var(--paper);
		margin: 2rem 0 0.75rem;
	}

	.post-content :global(p) {
		margin: 0 0 1.25rem;
		color: var(--paper);
		text-wrap: pretty;
	}

	.post-content :global(ul),
	.post-content :global(ol) {
		margin: 0 0 1.25rem;
		padding-left: 1.5rem;
		color: var(--paper);
	}

	.post-content :global(li) {
		margin-bottom: 0.4rem;
	}

	.post-content :global(ul li::marker) {
		color: var(--copper);
	}
	.post-content :global(ol li::marker) {
		color: var(--copper);
		font-family: var(--f-mono);
		font-size: 0.85em;
	}

	.post-content :global(strong) {
		font-weight: 600;
		color: var(--paper);
	}

	.post-content :global(em) {
		font-family: var(--f-display);
		font-style: italic;
		color: var(--paper);
	}

	.post-content :global(a) {
		color: var(--copper);
		border-bottom: 1px solid var(--copper-dim);
		transition: color 0.2s, border-color 0.2s;
	}
	.post-content :global(a:hover) {
		color: var(--paper);
		border-bottom-color: var(--paper);
	}

	.post-content :global(code) {
		font-family: var(--f-mono);
		font-size: 0.88em;
		background: var(--ink-2);
		color: var(--paper);
		padding: 0.15rem 0.45rem;
		border: 1px solid var(--rule);
	}

	.post-content :global(pre) {
		font-family: var(--f-mono);
		background: var(--ink-2);
		border: 1px solid var(--rule-strong);
		padding: 1.25rem 1.5rem;
		overflow-x: auto;
		margin: 0 0 1.5rem;
		line-height: 1.6;
	}

	.post-content :global(pre code) {
		background: none;
		border: none;
		padding: 0;
		font-size: 13px;
		color: var(--paper);
	}

	.post-content :global(blockquote) {
		border-left: 2px solid var(--copper);
		padding: 0.25rem 0 0.25rem 1.25rem;
		margin: 1.5rem 0;
		color: var(--paper-dim);
		font-family: var(--f-display);
		font-style: italic;
		font-size: 1.1em;
	}

	.post-content :global(hr) {
		border: none;
		border-top: 1px solid var(--rule);
		margin: 2.5rem 0;
	}

	.post-content :global(img) {
		max-width: 100%;
		margin: 1.5rem 0;
		border: 1px solid var(--rule);
	}

	.post-footer {
		padding: clamp(32px, 4vw, 48px) 0;
		border-top: 1px solid var(--rule);
	}
</style>
