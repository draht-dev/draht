---
import AtelierPage from "../layouts/AtelierPage.astro";

const title = "404 — Page Not Found · Draht";
const description = "The page you're looking for doesn't exist.";
---

<AtelierPage title={title} description={description}>
	<main class="error-main">
		<section class="error-page">
			<div class="error-code">404</div>
			<h1 class="error-title">Nicht gefunden<span class="amp">.</span></h1>
			<p class="error-desc">The page you're looking for doesn't exist or has been moved.</p>
			<div class="error-actions">
				<a href="/" class="btn">Back to Home →</a>
				<a href="/docs" class="btn ghost">Read the docs</a>
			</div>
		</section>
	</main>
</AtelierPage>

<style>
	.error-main {
		max-width: 720px;
		margin: 0 auto;
	}
	.error-page {
		padding: clamp(80px, 14vw, 180px) 0;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}
	.error-code {
		font-family: var(--f-mono);
		font-size: clamp(11px, 1vw, 12px);
		letter-spacing: 0.2em;
		color: var(--copper);
		text-transform: uppercase;
		margin-bottom: 28px;
	}
	.error-code::before {
		content: "· ";
		color: var(--copper-dim);
	}
	.error-title {
		font-family: var(--f-display);
		font-style: italic;
		font-weight: 300;
		font-size: clamp(64px, 14vw, 180px);
		line-height: 0.9;
		letter-spacing: -0.035em;
		color: var(--paper);
		margin: 0 0 32px;
	}
	.error-title .amp {
		color: var(--copper);
	}
	.error-desc {
		color: var(--paper-dim);
		font-family: var(--f-display);
		font-size: clamp(18px, 2vw, 22px);
		line-height: 1.5;
		margin: 0 0 40px;
		max-width: 36ch;
	}
	.error-actions {
		display: flex;
		gap: 16px;
		flex-wrap: wrap;
	}
</style>
