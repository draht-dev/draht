---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

const title = "Blog — Draht";
const description = "Articles about AI coding agents, freelance development, TDD, DDD, and building with Draht.";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
	.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Base title={title} description={description}>
	<main style="max-width: 700px; margin: 0 auto; padding: 2rem;">
		<h1 style="font-size: 2rem; font-weight: 700; margin-bottom: 2rem;">Blog</h1>

		{posts.length === 0 && (
			<p style="color: var(--muted); font-size: 0.875rem;">No posts yet. Check back soon.</p>
		)}

		{posts.map((post) => (
			<article style="margin-bottom: 2rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border);">
				<time style="color: var(--muted); font-size: 0.75rem;">{post.data.date}</time>
				<h2 style="font-size: 1.25rem; margin: 0.5rem 0;">
					<a href={`/blog/${post.id}`} style="color: var(--fg);">{post.data.title}</a>
				</h2>
				<p style="color: var(--muted); font-size: 0.875rem;">{post.data.description}</p>
				{post.data.tags && post.data.tags.length > 0 && (
					<div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.5rem;">
						{post.data.tags.map((tag: string) => (
							<span style="font-family: var(--mono); font-size: 0.65rem; color: var(--accent-dim); background: var(--accent-dark); padding: 0.15rem 0.5rem; border-radius: 3px;">{tag}</span>
						))}
					</div>
				)}
			</article>
		))}

		<p style="color: var(--muted); font-size: 0.875rem; text-align: center; margin-top: 2rem;">
			More articles coming soon. Follow us on <a href="https://github.com/draht-dev/draht">GitHub</a> for updates.
		</p>
	</main>
</Base>
