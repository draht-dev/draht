					<div class="pkg-tag">BIZ</div>
				</a>
				<a class="pkg" href="https://github.com/draht-dev/draht">
					<span class="pkg-idx">№ 09</span>
					<div class="pkg-name">@draht/templates <em>the patterns</em></div>
