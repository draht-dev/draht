					<div class="pkg-tag">CORE</div>
				</a>
				<a class="pkg" href="https://github.com/draht-dev/draht">
					<span class="pkg-idx">№ 02</span>
					<div class="pkg-name">@draht/orchestrator <em>the conductor</em></div>
