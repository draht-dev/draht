			],
			[
				{ t: "prompt", v: "$ " }, { t: "user", v: 'draht orchestrate "migrate auth to jwks"' },
				{ t: "nl" },
				{ t: "dim", v: "  ⚙︎  planning… 3 independent tracks identified" },
				{ t: "nl" },
				{ t: "dim", v: "  ├─ " }, { t: "key", v: "◆ " }, { t: "dim", v: "track/jwks-client      " }, { t: "ok", v: "haiku-4.5 · running" },
				{ t: "dim", v: "  ├─ " }, { t: "key", v: "◆ " }, { t: "dim", v: "track/middleware-swap  " }, { t: "ok", v: "sonnet-4.5 · running" },
				{ t: "dim", v: "  └─ " }, { t: "key", v: "◆ " }, { t: "dim", v: "track/key-rotation-doc " }, { t: "ok", v: "haiku-4.5 · running" },
				{ t: "nl" },
				{ t: "dim", v: "  merged 3/3 branches · 0 conflicts · €0.21 total" },
				{ t: "dim", v: "  ⏎ review diff · ⇧M open merge report" }
			],
			[
				{ t: "prompt", v: "$ " }, { t: "user", v: "draht invoice --month 2026-04 --client acme" },
				{ t: "nl" },
				{ t: "dim", v: "  ACME GmbH · 2026-04 · 47 tasks · 412,881 tokens" },
				{ t: "dim", v: "  ─────────────────────────────────────────" },
				{ t: "dim", v: "  haiku-4.5     " }, { t: "ok", v: "€  3.42" }, { t: "dim", v: "   · 31 tasks" },
				{ t: "dim", v: "  sonnet-4.5    " }, { t: "ok", v: "€ 18.07" }, { t: "dim", v: "   · 14 tasks" },
				{ t: "dim", v: "  opus-4.5      " }, { t: "ok", v: "€  4.91" }, { t: "dim", v: "   ·  2 tasks" },
				{ t: "dim", v: "  ─────────────────────────────────────────" },
				{ t: "dim", v: "  subtotal      " }, { t: "ok", v: "€ 26.40" },
				{ t: "dim", v: "  + margin 3×   " }, { t: "ok", v: "€ 79.20" },
				{ t: "dim", v: "  + 19% VAT     " }, { t: "ok", v: "€ 94.25" },
				{ t: "nl" },
				{ t: "dim", v: "  → invoice-2026-04-acme.pdf generated " }, { t: "ok", v: "✓" }
			]
		];

		const wait = (ms) => new Promise((r) => setTimeout(r, ms));

		async function typeScene(scene) {
			if (!term) return;
			term.innerHTML = "";
			let line = document.createElement("div");
			line.className = "line";
			term.appendChild(line);
			for (const part of scene) {
				if (part.t === "nl") {
					line = document.createElement("div");
					line.className = "line";
					term.appendChild(line);
					await wait(60);
					continue;
				}
				const span = document.createElement("span");
				span.className = "t-" + part.t;
				line.appendChild(span);
				const text = part.v;
				const step = part.t === "user" ? 14 : 2;
				for (let i = 0; i < text.length; i++) {
					span.textContent += text[i];
					if (part.t === "user" || i % 6 === 0) await wait(step);
				}
			}
			const cur = document.createElement("span");
			cur.className = "cursor";
			line.appendChild(cur);
		}

		(async function loop() {
			let i = 0;
			while (true) {
				await typeScene(scenes[i % scenes.length]);
				await wait(3800);
				i++;
			}
		})();

		// ---------- Copy buttons ----------
		document.querySelectorAll(".copy-btn[data-copy]").forEach((btn) => {
			btn.addEventListener("click", async () => {
				const text = btn.dataset.copy || "";
				try {
					await navigator.clipboard.writeText(text);
				} catch (e) {}
				const original = btn.textContent;
				btn.textContent = "Copied ✓";
				btn.style.color = "var(--patina)";
				setTimeout(() => {
					btn.textContent = original;
					btn.style.color = "";
				}, 1400);
			});
		});

		// ---------- WIRE PLAN (Schaltplan) ----------
		const SVG_NS = "http://www.w3.org/2000/svg";
		const wireSvg = document.getElementById("wire-svg");
		const wirePlan = document.getElementById("wireplan");

		function el(name, attrs = {}) {
			const n = document.createElementNS(SVG_NS, name);
			for (const k in attrs) n.setAttribute(k, attrs[k]);
			return n;
		}

		function orthoPath(points, r = 10) {
			if (points.length === 0) return "";
			if (points.length === 1) return `M ${points[0][0]} ${points[0][1]}`;
			let d = `M ${points[0][0]} ${points[0][1]}`;
			for (let i = 1; i < points.length - 1; i++) {
				const [px, py] = points[i - 1];
				const [x, y] = points[i];
				const [nx, ny] = points[i + 1];
				const dx1 = Math.sign(x - px), dy1 = Math.sign(y - py);
				const dx2 = Math.sign(nx - x), dy2 = Math.sign(ny - y);
				const rr = Math.min(
					r,
					Math.abs(x - px) / 2, Math.abs(y - py) / 2,
					Math.abs(nx - x) / 2, Math.abs(ny - y) / 2
				);
				const bx = x - dx1 * rr, by = y - dy1 * rr;
				const ax = x + dx2 * rr, ay = y + dy2 * rr;
				d += ` L ${bx} ${by} Q ${x} ${y} ${ax} ${ay}`;
			}
			const last = points[points.length - 1];
			d += ` L ${last[0]} ${last[1]}`;
			return d;
		}

		function addTrace(d, cls = "", extraAttrs = {}) {
			const p = el("path", { d, class: "wire-trace " + cls, ...extraAttrs });
			wireSvg.appendChild(p);
			return p;
		}
		function addPulse(d, dur = 6, delay = 0) {
			const p = el("path", { d, class: "wire-pulse" });
			p.style.animationDuration = dur + "s";
			p.style.animationDelay = -delay + "s";
			wireSvg.appendChild(p);
			return p;
		}
		// Emission that fires from a branch point whenever the main bus pulse
		// passes its Y position. The bus runs 14s/loop with two pulses offset
		// by 7s, so any point is hit every 7s — we sync to that cadence and
		// phase-lock using the path-length constant the flow keyframes use.
		function addEmission(d, busY) {
			const tFire = ((busY - 49) / 2018) * 14;
			const cycle = 7;
			const advance = ((cycle - (tFire % cycle)) % cycle + cycle) % cycle;
			const p = el("path", { d, class: "wire-emission" });
			p.style.animationDelay = (-advance) + "s";
			wireSvg.appendChild(p);
			return p;
		}
		// Bus-synced version of addPulse: an existing branch trace gets a flowing
		// dash pulse that starts traversing the path the moment the main bus
		// pulse passes the given Y. Uses the 7s cadence (two bus pulses / 14s).
		// `cascade` adds a positive-seconds delay so a downstream pulse can fire
		// the moment the upstream pulse arrives — pass the path distance the
		// signal has to cover times the per-second pulse speed (PX_PER_SEC).
		const PX_PER_SEC = 2018 / 7;
		function addBusPulse(d, busY, dur = 7, cascade = 0) {
			const tFire = ((busY - 49) / 2018) * 14 + cascade;
			const advance = ((dur - (tFire % dur)) % dur + dur) % dur;
			return addPulse(d, dur, advance);
		}
		function addNode(x, y, r = 3.5, cls = "") {
			const c = el("circle", { cx: x, cy: y, r, class: "wire-node " + cls });
			wireSvg.appendChild(c);
			return c;
		}
		function addLabel(x, y, text, cls = "", anchor = "start") {
			const t = el("text", { x, y, class: "wire-label " + cls, "text-anchor": anchor });
			t.textContent = text;
			wireSvg.appendChild(t);
			return t;
		}

		function rectOf(e) {
			const r = e.getBoundingClientRect();
			return {
				x: r.left,
				y: r.top + window.scrollY,
				w: r.width,
				h: r.height,
				right: r.right,
				cy: r.top + window.scrollY + r.height / 2
			};
		}

		function buildWirePlan() {
			if (!wireSvg || !wirePlan) return;
			wireSvg.innerHTML = "";
			const defs = el("defs");
			defs.innerHTML = `
				<radialGradient id="glowDot" cx="50%" cy="50%" r="50%">
					<stop offset="0%"  stop-color="currentColor" stop-opacity="1"/>
					<stop offset="50%" stop-color="currentColor" stop-opacity="0.3"/>
					<stop offset="100%" stop-color="currentColor" stop-opacity="0"/>
				</radialGradient>`;
			wireSvg.appendChild(defs);

			const W = window.innerWidth;
			const H = document.documentElement.scrollHeight;
			wireSvg.setAttribute("viewBox", `0 0 ${W} ${H}`);
			wireSvg.setAttribute("width", W);
			wireSvg.setAttribute("height", H);
			wirePlan.style.height = H + "px";
			wirePlan.style.position = "absolute";
			wirePlan.style.top = "0";

			const NARROW = W < 1100;
			if (NARROW) {
				const busD = `M 12 40 L 12 ${H - 40}`;
				addTrace(busD, "bus");
				addPulse(busD, 18, 0);
				return;
			}

			const rect = (sel) => {
				const e = document.querySelector(sel);
				if (!e) return null;
				const r = e.getBoundingClientRect();
				const top = r.top + window.scrollY;
				return {
					x: r.left, y: top, w: r.width, h: r.height,
					cx: r.left + r.width / 2, cy: top + r.height / 2,
					right: r.right, bottom: top + r.height
				};
			};

			const gutterL = 14;
			const gutterR = W - 14;

			const wrap = rect(".wrap");
			const railL = Math.max(gutterL, (wrap ? wrap.x : 20) - 28);
			const railR = Math.min(gutterR, (wrap ? wrap.x + wrap.w : W - 20) + 28);

			// Main vertical bus on the left
			const busPts = [[railL, 40], [railL, H - 40]];
			const busD = orthoPath(busPts, 0);
			addTrace(busD, "bus");
			addPulse(busD, 14, 0);
			addPulse(busD, 14, 7);

			const sections = [
				{ sel: ".hero h1",                   label: "00 · INIT" },
				{ sel: "#werkstatt .section-head",   label: "01 · ROUTE" },
				{ sel: ".workbench",                 label: "02 · WERKBANK" },
				{ sel: "#packages .section-head",    label: "03 · PACKAGES" },
				{ sel: "#philosophie .section-head", label: "04 · DOCTRIN" },
				{ sel: "#pricing .section-head",     label: "05 · PREISE" }
			];
			sections.forEach((s, i) => {
				const r = rect(s.sel);
				if (!r) return;
				const y = r.y + 18;
				const branchD = `M ${railL} ${y} L ${railL - 10} ${y}`;
				addTrace(branchD, "faint");
				addNode(railL, y, 3.5, i === 0 ? "solid" : "pulse");
				addEmission(branchD, y);
				if (railL > 80) {
					addLabel(railL - 16, y + 3, s.label, i === 0 ? "accent" : "", "end");
				}
			});

			// Right-side feeder bus
			const busR = [[railR, 120], [railR, H - 120]];
			addTrace(orthoPath(busR, 0), "faint");
			for (let y = 160; y < H - 160; y += 180) {
				addTrace(`M ${railR} ${y} L ${railR - 8} ${y}`, "faint");
			}

			// Hero: wire from bus → hero headline
			const install = rect(".hero .install");
			const hero = rect(".hero h1");
			if (install && hero) {
				const entry = [
					[railL, hero.y + 18],
					[hero.x - 30, hero.y + 18],
					[hero.x - 30, hero.y + hero.h - 12]
				];
				addTrace(orthoPath(entry, 12));
				addBusPulse(orthoPath(entry, 12), hero.y + 18);
				addNode(hero.x - 30, hero.y + hero.h - 12, 3.5, "pulse");

				const out = [
					[install.right + 6, install.cy],
					[railR - 8, install.cy]
				];
				addTrace(orthoPath(out, 8));
				addBusPulse(orthoPath(out, 8), install.cy);
				addNode(install.right + 6, install.cy, 3.5, "solid");
				addNode(railR, install.cy, 3.5, "pulse");

				addLabel(install.x, install.y - 10, "+5V · INSTALL.SH", "accent");
			}

			// "Wie es funktioniert" — circuit linking the 3 pins
			const pins = Array.from(document.querySelectorAll("#werkstatt .card .pin")).map((p) => {
				const r = p.getBoundingClientRect();
				return { x: r.left + r.width / 2, y: r.top + window.scrollY + r.height / 2 };
			});
			const sameRow = pins.length === 3 && Math.abs(pins[0].y - pins[2].y) < 10;
			if (sameRow) {
				const railY = pins[0].y - 28;
				const trunkL = pins[0].x - 80;
				const trunkR = pins[2].x + 80;
				const trunkY = railY;
				const trunkPath = `M ${trunkL} ${trunkY} L ${trunkR} ${trunkY}`;
				addTrace(trunkPath, "bus");
				addBusPulse(trunkPath, trunkY, 7, (trunkL - railL) / PX_PER_SEC);
				pins.forEach((p, i) => {
					const drop = `M ${p.x} ${trunkY} L ${p.x} ${p.y}`;
					addTrace(drop);
					addBusPulse(drop, trunkY, 7, (p.x - railL) / PX_PER_SEC);
					addNode(p.x, trunkY, 3.5, "solid");
					addNode(p.x, p.y, 4.5, "solid");
				});
				addLabel(pins[0].x + 12, trunkY - 8, "A1 → A2");
				addLabel(pins[1].x + 12, trunkY - 8, "A2 → A3");
				const feed = [
					[railL, trunkY],
					[trunkL, trunkY]
				];
				addTrace(orthoPath(feed, 0), "faint");
				addNode(railL, trunkY, 3.5, "pulse");
				addBusPulse(`M ${railL} ${trunkY} L ${trunkL} ${trunkY}`, trunkY);
				const gx = trunkR, gy = trunkY;
				const g = el("g");
				g.innerHTML = `
					<line x1="${gx}" y1="${gy}" x2="${gx + 14}" y2="${gy}" stroke="currentColor" stroke-width="1.2" class="wire-trace"/>
					<line x1="${gx + 14}" y1="${gy - 6}" x2="${gx + 14}" y2="${gy + 6}" stroke="currentColor" stroke-width="1.2"/>
					<line x1="${gx + 17}" y1="${gy - 3}" x2="${gx + 17}" y2="${gy + 3}" stroke="currentColor" stroke-width="1.2"/>
					<line x1="${gx + 20}" y1="${gy - 1}" x2="${gx + 20}" y2="${gy + 1}" stroke="currentColor" stroke-width="1.2"/>`;
				g.style.color = "var(--copper-dim)";
				g.style.opacity = "0.55";
				wireSvg.appendChild(g);
			}

			// Workbench — terminal to feature list
			const termR = rect(".terminal");
			const feats = Array.from(document.querySelectorAll(".feat")).map(rectOf);
			if (termR && feats.length) {
				const trunkX = (termR.x + termR.w + feats[0].x) / 2;
				const Tx = termR.x + termR.w + 4;
				const Ty = termR.y + 40;
				const out = [
					[Tx, Ty],
					[trunkX, Ty],
					[trunkX, feats[feats.length - 1].cy]
				];
				addTrace(orthoPath(out, 10), "bus");
				addBusPulse(orthoPath(out, 10), Ty);
				addNode(Tx, Ty, 3.5, "solid");
				feats.forEach((f, i) => {
					const d = `M ${trunkX} ${f.cy} L ${f.x - 6} ${f.cy}`;
					addTrace(d);
					// Cascade: time for the out pulse to travel from T0 along the
					// horizontal leg + down the vertical leg to (trunkX, f.cy).
					const pathToDrop = (trunkX - Tx) + (f.cy - Ty);
					addBusPulse(d, Ty, 7, pathToDrop / PX_PER_SEC);
					addNode(trunkX, f.cy, 3, "pulse");
					addNode(f.x - 6, f.cy, 3, "solid");
				});
			}

			// Packages — comb with animated scans
			const pkgs = Array.from(document.querySelectorAll(".pkg")).map(rectOf);
			if (pkgs.length) {
				const spineX = railR - 40;
				const top = pkgs[0].y + 20;
				const bot = pkgs[pkgs.length - 1].y + pkgs[pkgs.length - 1].h - 20;
				const spineD = `M ${spineX} ${top} L ${spineX} ${bot}`;
				addTrace(spineD, "bus");
				addBusPulse(spineD, top);
				pkgs.forEach((p, i) => {
					const y = p.y + p.h / 2;
					const d = `M ${spineX} ${y} L ${spineX + 30} ${y}`;
					addTrace(d);
					addNode(spineX, y, 3, i % 2 === 0 ? "solid" : "pulse");
					addNode(spineX + 30, y, 2.5);
				});
			}

			// Philosophy — subtle cross marks at row boundaries
			const clauses = Array.from(document.querySelectorAll(".clause")).map(rectOf);
			if (clauses.length >= 4) {
				const leftCol = clauses[0];
				const centerX = leftCol.x + leftCol.w;
				for (let i = 0; i < clauses.length - 2; i += 2) {
					const c = clauses[i];
					const y = c.y + c.h;
					const g = el("g");
					g.setAttribute("opacity", "0.4");
					g.innerHTML = `
						<line x1="${centerX - 4}" y1="${y}" x2="${centerX + 4}" y2="${y}" stroke="currentColor" stroke-width="1" style="color:var(--copper-dim)"/>
						<line x1="${centerX}" y1="${y - 4}" x2="${centerX}" y2="${y + 4}" stroke="currentColor" stroke-width="1" style="color:var(--copper-dim)"/>`;
					wireSvg.appendChild(g);
				}
			}

			// Hero install — converging bus under the twin install cards
			const installs = Array.from(document.querySelectorAll("#hero-install .install")).map(rectOf);
			if (installs.length >= 2) {
				const a = installs[0], b = installs[1];
				const busY = Math.max(a.y + a.h, b.y + b.h) + 14;
				addTrace(orthoPath([
					[a.x + a.w / 2, a.y + a.h + 2],
					[a.x + a.w / 2, busY],
					[b.x + b.w / 2, busY],
					[b.x + b.w / 2, b.y + b.h + 2]
				], 6), "faint");
				addNode(a.x + a.w / 2, a.y + a.h + 2, 2.5);
				addNode(b.x + b.w / 2, b.y + b.h + 2, 2.5);
			}

			// Resistor-like squiggle aligned with the hero tagline
			const tagEl = document.querySelector(".hero .tag");
			if (tagEl) {
				const t = rectOf(tagEl);
				const ry = t.y + t.h / 2;
				const rx = railR - 180;
				const z = [];
				let x = rx;
				for (let i = 0; i < 6; i++) {
					z.push([x, ry + (i % 2 ? -4 : 4)]);
					x += 6;
				}
				addTrace(
					`M ${rx - 20} ${ry} L ${rx} ${ry} ${z.map((p) => `L ${p[0]} ${p[1]}`).join(" ")} L ${rx + 60} ${ry}`,
					"faint"
				);
				addNode(rx - 20, ry, 2.5);
				addNode(rx + 60, ry, 2.5);
				addLabel(rx - 2, ry - 10, "R₁ · ROUTER");
			}
		}

		let rebuildT;
		function rebuild() {
			clearTimeout(rebuildT);
			rebuildT = setTimeout(buildWirePlan, 80);
		}
		window.addEventListener("resize", rebuild);
		if (document.fonts && document.fonts.ready) {
			document.fonts.ready.then(rebuild);
		}
		setTimeout(rebuild, 300);
		setTimeout(rebuild, 1200);
		setTimeout(rebuild, 2500);

		buildWirePlan();
	</script>

	<style is:global>
		:root {
			--ink:        #0e0d0b;
			--ink-2:      #14110d;
			--paper:      #efe7d8;
			--paper-dim:  #c9bfae;
			--paper-soft: #8b8472;
			--rule:       rgba(239, 231, 216, 0.14);
			--rule-strong:rgba(239, 231, 216, 0.28);
			--copper:     oklch(0.72 0.13 55);
			--copper-dim: oklch(0.55 0.11 55);
			--patina:     oklch(0.68 0.06 175);

			--f-display: "Instrument Serif", "Times New Roman", serif;
			--f-ui:      "Instrument Sans", ui-sans-serif, system-ui, sans-serif;
			--f-mono:    "Geist Mono", "JetBrains Mono", ui-monospace, monospace;

			--gutter: clamp(20px, 4vw, 56px);
			--max:    1240px;
		}

		* { box-sizing: border-box; }
		html, body { margin: 0; padding: 0; }
		body {
			background: var(--ink);
			color: var(--paper);
			font-family: var(--f-ui);
			font-weight: 400;
			-webkit-font-smoothing: antialiased;
			font-feature-settings: "ss01", "ss02", "cv01";
			overflow-x: hidden;
		}

		body::before {
			content: "";
			position: fixed;
			inset: 0;
			pointer-events: none;
			background-image:
				radial-gradient(circle at 20% 10%, rgba(217, 185, 128, 0.06), transparent 40%),
				radial-gradient(circle at 80% 60%, rgba(120, 150, 150, 0.04), transparent 45%);
			mix-blend-mode: screen;
			z-index: 0;
		}
		body::after {
			content: "";
			position: fixed;
			inset: 0;
			pointer-events: none;
			background-image:
				repeating-linear-gradient(0deg, transparent 0 3px, rgba(0, 0, 0, 0.18) 3px 4px);
			opacity: 0.25;
			mix-blend-mode: multiply;
			z-index: 1;
		}

		a { color: inherit; text-decoration: none; }

		.wrap {
			position: relative;
			z-index: 2;
			max-width: var(--max);
			margin: 0 auto;
			padding: 0 var(--gutter);
		}

		/* ---------- Topbar ---------- */
		.topbar {
			display: flex;
			align-items: center;
			justify-content: space-between;
			padding-top: 28px;
			padding-bottom: 14px;
			border-bottom: 1px solid var(--rule);
		}
		.brand {
			display: flex;
			align-items: center;
			gap: 14px;
			font-family: var(--f-ui);
			letter-spacing: 0.02em;
		}
		.brand .mark {
			width: 34px;
			height: 34px;
			display: grid;
			place-items: center;
			position: relative;
		}
		.brand .mark img {
			width: 100%;
			height: 100%;
			object-fit: contain;
			filter: drop-shadow(0 0 6px rgba(217, 140, 70, 0.18));
		}
		.brand .wordmark {
			font-size: 15px;
			letter-spacing: 0.06em;
			text-transform: lowercase;
		}
		.brand .wordmark em {
			font-style: normal;
			color: var(--paper-soft);
		}

		.nav {
			display: flex;
			gap: 28px;
			font-size: 13px;
			letter-spacing: 0.06em;
			text-transform: uppercase;
			color: var(--paper-soft);
		}
		.nav a {
			position: relative;
			padding: 4px 0;
		}
		.nav a:hover { color: var(--paper); }
		.nav a::after {
			content: "";
			position: absolute;
			left: 0;
			right: 0;
			bottom: -2px;
			height: 1px;
			background: var(--copper);
			transform: scaleX(0);
			transform-origin: left;
			transition: transform 0.3s ease;
		}
		.nav a:hover::after { transform: scaleX(1); }

		.meta-strip {
			display: flex;
			justify-content: space-between;
			align-items: center;
			font-family: var(--f-mono);
			font-size: 11px;
			color: var(--paper-soft);
			letter-spacing: 0.04em;
			padding: 10px 0;
			border-bottom: 1px solid var(--rule);
		}
		.meta-strip .dot {
			width: 6px;
			height: 6px;
			border-radius: 50%;
			background: var(--patina);
			display: inline-block;
			margin-right: 8px;
			vertical-align: middle;
			animation: blink 2.4s infinite;
		}
		@keyframes blink {
			0%, 100% { opacity: 1; }
			50%      { opacity: 0.25; }
		}

		/* ---------- Hero ---------- */
		.hero {
			position: relative;
			padding: clamp(64px, 10vw, 140px) 0 clamp(80px, 12vw, 180px);
		}

		.tag {
			display: inline-flex;
			align-items: center;
			gap: 10px;
			font-family: var(--f-mono);
			font-size: 11px;
			letter-spacing: 0.18em;
			text-transform: uppercase;
			color: var(--copper);
			margin-bottom: 40px;
		}
		.tag::before {
			content: "";
			width: 24px;
			height: 1px;
			background: var(--copper);
		}

		.hero h1 {
			font-family: var(--f-display);
			font-weight: 300;
			font-size: clamp(72px, 16vw, 240px);
			line-height: 0.88;
			letter-spacing: -0.035em;
			margin: 0 0 36px;
			color: var(--paper);
			font-style: italic;
		}
		.hero h1 .ampersand {
			font-style: italic;
			color: var(--copper);
			font-weight: 300;
		}
		.hero h1 .small {
			display: block;
			font-size: 0.18em;
			letter-spacing: -0.01em;
			color: var(--paper-dim);
			font-style: normal;
			font-weight: 400;
			margin-top: 18px;
			max-width: 12em;
			line-height: 1.2;
		}

		.hero-grid {
			display: grid;
			grid-template-columns: 1.1fr 1fr;
			gap: clamp(40px, 6vw, 96px);
			align-items: end;
		}

		.hero-lede {
			font-family: var(--f-display);
			font-size: clamp(20px, 2vw, 26px);
			font-weight: 400;
			line-height: 1.45;
			color: var(--paper);
			max-width: 34ch;
			text-wrap: pretty;
		}
		.hero-lede .drop {
			font-style: italic;
			color: var(--copper);
		}

		.hero-cta {
			display: flex;
			flex-direction: column;
			gap: 20px;
			align-items: flex-start;
		}
		.hero-meta {
			font-family: var(--f-mono);
			font-size: 10px;
			letter-spacing: 0.14em;
			text-transform: uppercase;
			color: var(--paper-soft);
		}
		.hero-install {
			margin-top: clamp(40px, 5vw, 72px);
			position: relative;
			z-index: 2;
		}
		.hero-install .install-col {
			padding: clamp(22px, 2.2vw, 32px);
		}
		.hero-install .install-badge {
			margin-bottom: 18px;
		}
		.hero-install .install-badge .ib-num {
			font-size: 40px;
		}
		.hero-install .install-badge .ib-title {
			font-size: 20px;
		}
		.hero-install .install-note {
			font-size: 13px;
			margin-top: 14px;
			max-width: 38ch;
		}
		.install {
			font-family: var(--f-mono);
			background: var(--ink-2);
			border: 1px solid var(--rule-strong);
			padding: 14px 18px;
			font-size: 13px;
			color: var(--paper);
			display: flex;
			gap: 12px;
			align-items: center;
			width: 100%;
			max-width: 460px;
			position: relative;
		}
		.install::before {
			content: "";
			position: absolute;
			left: -6px;
			top: 50%;
			transform: translateY(-50%);
			width: 12px;
			height: 12px;
			border-radius: 50%;
			background: var(--copper);
			box-shadow: 0 0 0 2px var(--ink), 0 0 12px rgba(217, 140, 70, 0.6);
		}
		.install .prompt {
			color: var(--copper);
			user-select: none;
		}
		.install code {
			flex: 1;
			white-space: nowrap;
			overflow: hidden;
			text-overflow: ellipsis;
		}
		.install button {
			background: transparent;
			border: 1px solid var(--rule-strong);
			color: var(--paper-soft);
			font-family: var(--f-mono);
			font-size: 10px;
			letter-spacing: 0.1em;
			text-transform: uppercase;
			padding: 5px 10px;
			cursor: pointer;
			transition: all 0.2s;
		}
		.install button:hover {
			color: var(--copper);
			border-color: var(--copper);
		}

		.cta-row {
			display: flex;
			gap: 18px;
			align-items: center;
			font-size: 13px;
		}
		.btn {
			display: inline-flex;
			align-items: center;
			gap: 10px;
			padding: 12px 22px;
			background: var(--paper);
			color: var(--ink);
			font-family: var(--f-ui);
			font-weight: 500;
			letter-spacing: 0.02em;
			border: 1px solid var(--paper);
			transition: all 0.2s;
		}
		.btn:hover {
			background: var(--copper);
			border-color: var(--copper);
			color: var(--ink);
		}
		.btn.ghost {
			background: transparent;
			color: var(--paper-soft);
			border-color: var(--rule-strong);
		}
		.btn.ghost:hover {
			color: var(--paper);
			border-color: var(--paper);
		}

		/* ---------- Schematic border + wire routing ---------- */
		.schematic {
			position: absolute;
			inset: 0;
			pointer-events: none;
			z-index: 0;
		}
		.schematic svg { width: 100%; height: 100%; }

		/* ---------- Global wire layer (Schaltplan) ---------- */
		.wireplan {
			position: fixed;
			inset: 0;
			pointer-events: none;
			z-index: 1;
		}
		.wireplan svg {
			width: 100%;
			height: 100%;
			display: block;
		}

		.wire-trace {
			fill: none;
			stroke: var(--copper);
			stroke-width: 1.25;
			stroke-linecap: round;
			stroke-linejoin: round;
			opacity: 0.55;
			filter: drop-shadow(0 0 3px color-mix(in oklab, var(--copper), transparent 60%));
		}
		.wire-trace.faint {
			stroke: var(--copper-dim);
			opacity: 0.32;
			stroke-width: 1;
		}
		.wire-trace.bus {
			stroke-width: 1.5;
			opacity: 0.75;
		}
		.wire-trace.dashed {
			stroke: var(--paper-soft);
			stroke-dasharray: 2 5;
			opacity: 0.35;
			stroke-width: 1;
			filter: none;
		}

		.wire-pulse {
			fill: none;
			stroke: var(--copper);
			stroke-width: 2;
			stroke-linecap: round;
			filter: drop-shadow(0 0 6px var(--copper)) drop-shadow(0 0 14px var(--copper-dim));
			stroke-dasharray: 18 2000;
			animation: flow linear infinite;
		}
		@keyframes flow {
			from { stroke-dashoffset: 0; }
			to   { stroke-dashoffset: -2018; }
		}

		.wire-emission {
			fill: none;
			stroke: var(--copper);
			stroke-width: 2;
			stroke-linecap: round;
			stroke-dasharray: 4 200;
			filter: drop-shadow(0 0 5px var(--copper)) drop-shadow(0 0 12px var(--copper-dim));
			animation: emitFlow 7s linear infinite;
		}
		@keyframes emitFlow {
			from { stroke-dashoffset: 0; }
			to   { stroke-dashoffset: -204; }
		}

		.wire-node {
			fill: var(--ink);
			stroke: var(--copper);
			stroke-width: 1.25;
		}
		.wire-node.solid {
			fill: var(--copper);
			stroke: none;
		}
		.wire-node.pulse {
			animation: nodePulse 2.8s ease-in-out infinite;
			transform-origin: center;
			transform-box: fill-box;
		}
		@keyframes nodePulse {
			0%, 100% { opacity: 0.4; }
			50%      { opacity: 1; filter: drop-shadow(0 0 8px var(--copper)); }
		}

		.wire-label {
			fill: var(--paper-soft);
			font-family: var(--f-mono);
			font-size: 9px;
			letter-spacing: 0.15em;
			text-transform: uppercase;
			opacity: 0.55;
		}
		.wire-label.accent {
			fill: var(--copper);
			opacity: 0.8;
		}

		.wire-draw {
			stroke-dasharray: var(--len, 1000);
			stroke-dashoffset: var(--len, 1000);
			transition: stroke-dashoffset 1.6s cubic-bezier(0.2, 0.7, 0.2, 1);
		}
		.revealed .wire-draw { stroke-dashoffset: 0; }

		@media (prefers-reduced-motion: reduce) {
			.wire-pulse, .wire-node.pulse, .wire-emission { animation: none !important; }
			.wire-draw { stroke-dashoffset: 0 !important; }
		}

		/* ---------- Section header ---------- */
		.section {
			position: relative;
			padding: clamp(80px, 10vw, 140px) 0;
			border-top: 1px solid var(--rule);
		}
		.section-head {
			display: grid;
			grid-template-columns: auto 1fr auto;
			gap: 32px;
			align-items: baseline;
			margin-bottom: 64px;
			padding-bottom: 18px;
			border-bottom: 1px solid var(--rule);
		}
		.section-num {
			font-family: var(--f-mono);
			font-size: 12px;
			color: var(--copper);
			letter-spacing: 0.1em;
		}
		.section-title {
			font-family: var(--f-display);
			font-style: italic;
			font-weight: 300;
			font-size: clamp(32px, 4vw, 56px);
			line-height: 1;
			letter-spacing: -0.02em;
			color: var(--paper);
		}
		.section-title em {
			font-family: var(--f-display);
			font-style: normal;
			color: var(--paper-soft);
			font-size: 0.5em;
			letter-spacing: 0;
			margin-left: 14px;
			text-transform: lowercase;
		}
		.section-kicker {
			font-family: var(--f-mono);
			font-size: 11px;
			color: var(--paper-soft);
			letter-spacing: 0.15em;
			text-transform: uppercase;
			text-align: right;
		}

		/* ---------- How it works ---------- */
		.wires {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: clamp(20px, 3vw, 48px);
			position: relative;
		}
		.card .pin { opacity: 0; }
		.card {
			position: relative;
			padding-top: 64px;
		}
		.card .pin {
			position: absolute;
			top: 18px;
			left: 50%;
			transform: translateX(-50%);
			width: 28px;
			height: 28px;
			border-radius: 50%;
			background: var(--ink);
			border: 1px solid var(--rule-strong);
			display: grid;
			place-items: center;
			z-index: 1;
		}
		.card .pin::before {
			content: "";
			width: 8px;
			height: 8px;
			border-radius: 50%;
			background: var(--copper);
			box-shadow: 0 0 12px rgba(217, 140, 70, 0.8);
		}
		.card h3 {
			font-family: var(--f-display);
			font-weight: 400;
			font-style: italic;
			font-size: 28px;
			letter-spacing: -0.01em;
			margin: 0 0 14px;
			color: var(--paper);
		}
		.card p {
			color: var(--paper-dim);
			font-size: 15px;
			line-height: 1.55;
			margin: 0;
			text-wrap: pretty;
		}
		.card .label {
			font-family: var(--f-mono);
			font-size: 10px;
			letter-spacing: 0.15em;
			text-transform: uppercase;
			color: var(--copper);
			margin-bottom: 8px;
		}

		/* ---------- Terminal + features side by side ---------- */
		.workbench {
			display: grid;
			grid-template-columns: 1.2fr 1fr;
			gap: clamp(32px, 5vw, 72px);
			align-items: start;
		}
		.terminal {
			background: var(--ink-2);
			border: 1px solid var(--rule-strong);
			font-family: var(--f-mono);
			font-size: 13px;
			line-height: 1.6;
			position: relative;
			overflow: hidden;
		}
		.terminal .tbar {
			display: flex;
			align-items: center;
			gap: 8px;
			padding: 10px 14px;
			border-bottom: 1px solid var(--rule);
			font-size: 10px;
			color: var(--paper-soft);
			letter-spacing: 0.1em;
			text-transform: uppercase;
		}
		.terminal .tbar .tdots {
			display: flex;
			gap: 6px;
			margin-right: 12px;
		}
		.terminal .tbar .tdots i {
			width: 8px;
			height: 8px;
			border-radius: 50%;
			display: inline-block;
			background: #3a332a;
		}
		.terminal .body {
			padding: 20px 22px;
			min-height: 320px;
		}
		.terminal .line { white-space: pre-wrap; }
		.t-prompt { color: var(--copper); }
		.t-user   { color: var(--paper); }
		.t-dim    { color: var(--paper-soft); }
		.t-ok     { color: var(--patina); }
		.t-key    { color: var(--copper); }
		.cursor {
			display: inline-block;
			width: 8px;
			height: 14px;
			background: var(--copper);
			vertical-align: middle;
			margin-left: 2px;
			animation: cursorBlink 1s step-end infinite;
		}
		@keyframes cursorBlink {
			50% { opacity: 0; }
		}

		.feat-list {
			display: grid;
			gap: 22px;
		}
		.feat {
			display: grid;
			grid-template-columns: 56px 1fr;
			gap: 18px;
			padding: 18px 0;
			border-bottom: 1px solid var(--rule);
		}
		.feat:last-child { border-bottom: none; }
		.feat .fnum {
			font-family: var(--f-mono);
			font-size: 11px;
			color: var(--paper-soft);
			letter-spacing: 0.1em;
			padding-top: 4px;
		}
		.feat h4 {
			font-family: var(--f-display);
			font-weight: 500;
			font-size: 20px;
			margin: 0 0 6px;
			color: var(--paper);
			letter-spacing: -0.01em;
		}
		.feat p {
			margin: 0;
			font-size: 14px;
			line-height: 1.5;
			color: var(--paper-dim);
		}
		.feat h4 em {
			font-style: italic;
			color: var(--copper);
			font-weight: 400;
		}

		/* ---------- Philosophy ---------- */
		.manifest {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: 2px;
			background: var(--rule);
			border: 1px solid var(--rule);
		}
		.clause {
			background: var(--ink);
			padding: clamp(24px, 3vw, 40px);
			position: relative;
		}
		.clause .cnum {
			font-family: var(--f-display);
			font-style: italic;
			font-weight: 300;
			font-size: 72px;
			line-height: 1;
			color: var(--copper);
			margin-bottom: 12px;
			letter-spacing: -0.04em;
		}
		.clause .neg {
			font-family: var(--f-mono);
			font-size: 11px;
			letter-spacing: 0.15em;
			text-transform: uppercase;
			color: var(--paper-soft);
			margin-bottom: 8px;
		}
		.clause h5 {
			font-family: var(--f-display);
			font-style: italic;
			font-weight: 400;
			font-size: 28px;
			margin: 0 0 12px;
			color: var(--paper);
			letter-spacing: -0.01em;
		}
		.clause p {
			margin: 0;
			font-size: 14px;
			line-height: 1.6;
			color: var(--paper-dim);
			max-width: 42ch;
		}

		/* ---------- Install split ---------- */
		.install-split {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 2px;
			background: var(--rule);
			border: 1px solid var(--rule);
		}
		.install-col {
			background: var(--ink);
			padding: clamp(28px, 3vw, 44px);
		}
		.install-badge {
			display: flex;
			gap: 16px;
			align-items: flex-start;
			margin-bottom: 24px;
		}
		.install-badge .ib-num {
			font-family: var(--f-display);
			font-style: italic;
			font-weight: 300;
			font-size: 48px;
			line-height: 1;
			color: var(--copper);
			letter-spacing: -0.04em;
		}
		.install-badge .ib-title {
			font-family: var(--f-display);
			font-size: 22px;
			color: var(--paper);
			letter-spacing: -0.01em;
			margin-bottom: 4px;
		}
		.install-badge .ib-sub {
			font-family: var(--f-mono);
			font-size: 11px;
			letter-spacing: 0.08em;
			text-transform: uppercase;
			color: var(--paper-soft);
		}
		.install-note {
			margin: 18px 0 0;
			font-family: var(--f-display);
			font-size: 15px;
			line-height: 1.55;
			color: var(--paper-dim);
			max-width: 44ch;
		}

		/* ---------- Pricing ---------- */
		.pricing {
			display: grid;
			grid-template-columns: 1fr 1fr 1fr;
			gap: 2px;
			background: var(--rule);
			border: 1px solid var(--rule);
		}
		.tier {
			background: var(--ink);
			padding: clamp(28px, 3vw, 40px);
			display: flex;
			flex-direction: column;
			position: relative;
		}
		.tier.featured {
			background: linear-gradient(180deg, rgba(217, 140, 70, 0.05), transparent 70%);
		}
		.tier.featured::before {
			content: "Empfohlen";
			position: absolute;
			top: 16px;
			right: 16px;
			font-family: var(--f-mono);
			font-size: 10px;
			letter-spacing: 0.15em;
			text-transform: uppercase;
			color: var(--copper);
			padding: 4px 8px;
			border: 1px solid var(--copper);
		}
		.tier-num {
			font-family: var(--f-mono);
			font-size: 11px;
			letter-spacing: 0.15em;
			color: var(--paper-soft);
			margin-bottom: 12px;
		}
		.tier-name {
			font-family: var(--f-display);
			font-style: italic;
			font-weight: 400;
			font-size: 36px;
			color: var(--paper);
			letter-spacing: -0.02em;
			margin-bottom: 6px;
		}
		.tier-tag {
			font-family: var(--f-mono);
			font-size: 11px;
			letter-spacing: 0.08em;
			text-transform: uppercase;
			color: var(--paper-soft);
			margin-bottom: 24px;
		}
		.tier-price {
			font-family: var(--f-display);
			font-size: 56px;
			font-weight: 300;
			color: var(--copper);
			letter-spacing: -0.04em;
			line-height: 1;
			margin-bottom: 4px;
		}
		.tier-price em {
			font-size: 16px;
			font-style: italic;
