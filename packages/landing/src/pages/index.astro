					<div class="pkg-tag">OPS</div>
				</a>
				<a class="pkg" href="https://github.com/draht-dev/draht">
					<span class="pkg-idx">№ 06</span>
					<div class="pkg-name">@draht/deploy-guardian <em>the sentinel</em></div>
