					<div class="pkg-tag">CORE</div>
				</a>
				<a class="pkg" href="https://github.com/draht-dev/draht">
					<span class="pkg-idx">№ 03</span>
					<div class="pkg-name">@draht/knowledge <em>the domain</em></div>
