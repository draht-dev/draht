				{ t: "dim", v: "  ↳ " }, { t: "key", v: "edit     " }, { t: "dim", v: "src/payments/charge.ts        " }, { t: "ok", v: "±34" },
				{ t: "dim", v: "  ↳ " }, { t: "key", v: "ci       " }, { t: "dim", v: "bun test · 142 pass          " }, { t: "ok", v: "✓ green" },
				{ t: "dim", v: "  ↳ " }, { t: "key", v: "invoice  " }, { t: "dim", v: "logged · 18,402 tok · €0.074" },
				{ t: "nl" },
				{ t: "user", v: "  Done. Idempotency-Key header; 24h Redis TTL;" },
